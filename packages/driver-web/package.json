{
  "name": "@remelondb/driver-web",
  "version": "0.0.3",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker.ts"
  },
  "dependencies": {
    "@remelondb/core": "workspace:*",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1"
  },
  "devDependencies": {
    "@remelondb/driver-conformance": "workspace:*",
    "@vitest/browser": "^3.2.7",
    "playwright": "^1.61.1",
    "webdriverio": "^9.29.1"
  },
  "scripts": {
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "build": "tsdown && node scripts/fix-worker-url.mjs",
    "prepack": "tsdown && node scripts/fix-worker-url.mjs",
    "smoke:vite": "node scripts/vite-smoke.mjs"
  },
  "license": "MIT",
  "description": "remelonDB SqliteDriver for the browser (SQLite-WASM + OPFS in a Worker)",
  "keywords": [
    "remelondb",
    "watermelondb",
    "sqlite",
    "offline-first",
    "database",
    "sync"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dustyway/remelonDB.git",
    "directory": "packages/driver-web"
  },
  "homepage": "https://github.com/dustyway/remelonDB#readme",
  "bugs": "https://github.com/dustyway/remelonDB/issues",
  "sideEffects": false,
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./worker": {
        "types": "./dist/worker.d.mts",
        "import": "./dist/worker.mjs"
      }
    },
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "scripts"
  ]
}
