{
  "name": "@remelondb/zod",
  "version": "0.0.7",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@remelondb/core": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "zod": "^4.4.3"
  },
  "license": "MIT",
  "description": "Zod adapter for remelonDB: derive client tables from shared Zod schemas (zodTable) and validate both sync directions with wire schemas built from the same objects (syncSchemas)",
  "keywords": [
    "remelondb",
    "watermelondb",
    "zod",
    "sqlite",
    "offline-first",
    "database",
    "sync",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dustyway/remelonDB.git",
    "directory": "packages/zod"
  },
  "homepage": "https://github.com/dustyway/remelonDB#readme",
  "bugs": "https://github.com/dustyway/remelonDB/issues",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "prepack": "tsdown"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    },
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ]
}
