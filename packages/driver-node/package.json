{
  "name": "@remelondb/driver-node",
  "version": "0.0.8",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@remelondb/core": "workspace:*",
    "better-sqlite3": "^12.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0"
  },
  "license": "MIT",
  "description": "remelonDB SqliteDriver for Node (better-sqlite3)",
  "keywords": [
    "remelondb",
    "watermelondb",
    "sqlite",
    "offline-first",
    "database",
    "sync"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dustyway/remelonDB.git",
    "directory": "packages/driver-node"
  },
  "homepage": "https://github.com/dustyway/remelonDB#readme",
  "bugs": "https://github.com/dustyway/remelonDB/issues",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "prepack": "tsdown"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    },
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ]
}
